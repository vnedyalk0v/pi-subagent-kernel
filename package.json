{
  "name": "pi-subagent-kernel",
  "version": "0.1.0-beta.0",
  "private": true,
  "description": "Safe Pi extension kernel for explicit subagent runs, registries, and mock/subprocess backends.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "subagents",
    "agent-orchestration",
    "coding-agent"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vnedyalk0v/pi-subagent-kernel.git"
  },
  "bugs": {
    "url": "https://github.com/vnedyalk0v/pi-subagent-kernel/issues"
  },
  "homepage": "https://github.com/vnedyalk0v/pi-subagent-kernel#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "test": "node --test tests/**/*.test.ts",
    "demo:mock": "npm run build && node examples/mock-backend-demo.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
